# Akomi Backend Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Server Configuration
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
DB_TYPE=sqlite
DB_PATH=./akomi.db

# For PostgreSQL (future)
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=akomi
# DB_USER=akomi
# DB_PASSWORD=

# ============================================
# Authentication
# ============================================
JWT_SECRET=your-production-jwt-secret-min-32-chars
JWT_EXPIRES_IN=24h

# ============================================
# SKALE BITE Protocol Configuration
# ============================================
# SKALE Network ID (e.g., 'skale-mainnet', 'skale-testnet')
SKALE_NETWORK_ID=skale-mainnet

# BITE Contract Address on SKALE network
BITE_CONTRACT_ADDRESS=0x...

# Threshold Configuration (minimum validators required)
BITE_THRESHOLD=2
BITE_VALIDATORS=3

# SKALE RPC Endpoint
SKALE_RPC_URL=https://mainnet.skalenodes.com/v1/...

# ============================================
# CDP Wallet Configuration
# ============================================
# Coinbase Developer Platform Wallet
CDP_API_KEY=your-cdp-api-key
CDP_API_SECRET=your-cdp-api-secret

# Wallet Configuration
WALLET_PRIVATE_KEY=your-wallet-private-key
MERCHANT_ADDRESS=0x... # Where subscription payments go

# ============================================
# x402 Payment Protocol
# ============================================
# Enable x402 protocol for HTTP 402 payments
USE_X402=true
X402_ENDPOINT=https://api.x402.org/pay

# Payment token (e.g., 'USDC', 'ETH')
PAYMENT_TOKEN=USDC

# ============================================
# SLA / Metrics Provider
# ============================================
# Provider: 'datadog', 'newrelic', 'custom'
SLA_PROVIDER=datadog
SLA_API_ENDPOINT=https://api.datadoghq.com/api/v1
SLA_API_KEY=your-datadog-api-key

# Or use custom SLA endpoint
# SLA_API_ENDPOINT=https://your-sla-provider.com/api
# SLA_API_KEY=your-api-key

# Set to false to use real SLA data (true = mock for testing)
USE_MOCK_SLA=false

# ============================================
# External APIs (Placeholders)
# ============================================
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
EMAIL_API_KEY=
EMAIL_FROM=noreply@akomi.app

# Cloud monitoring (optional)
CLOUDWATCH_ENABLED=false
GOOGLE_CLOUD_ENABLED=false

# Vendor API keys (comma-separated)
VENDOR_API_KEYS=

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_CONSOLE=true
LOG_FILE=true
LOG_PATH=./logs

# ============================================
# Scheduler
# ============================================
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=3600000
MAX_CONCURRENT_EXECUTIONS=5
SCHEDULER_MAX_RETRIES=3
SCHEDULER_RETRY_DELAY=5000

# ============================================
# Feature Flags
# ============================================
FEATURE_AUTH=true
FEATURE_ENCRYPTION=true
FEATURE_PAYMENTS=true
FEATURE_NOTIFICATIONS=false
FEATURE_AUDIT=true
FEATURE_SCHEDULER=true

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173
